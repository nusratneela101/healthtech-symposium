APP_NAME="Canada Fintech Symposium"
APP_URL="https://fintech.softandpix.com"
APP_VERSION="2.0.0"

DB_HOST=localhost
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_pass

# Microsoft 365 Outlook SMTP
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=info@canadafintechsymposium.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM_EMAIL=info@canadafintechsymposium.com
SMTP_FROM_NAME="Canada Fintech Symposium"

# Microsoft 365 IMAP (for inbox polling)
IMAP_HOST="{outlook.office365.com:993/imap/ssl}INBOX"
IMAP_USER=info@canadafintechsymposium.com
IMAP_PASS=your_imap_password_here

# Brevo API (optional - for open/click tracking)
BREVO_API_KEY=your_brevo_api_key

# Microsoft 365 OAuth2 (for modern auth)
MS_OAUTH_CLIENT_ID=your_azure_client_id
MS_OAUTH_CLIENT_SECRET=your_azure_client_secret
MS_OAUTH_TENANT_ID=common
MS_OAUTH_REDIRECT_URI=https://fintech.softandpix.com/api/msgraph/callback.php

N8N_API_KEY=your_secure_api_key
SESSION_NAME=fts_session
