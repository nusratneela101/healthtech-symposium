# ---------------------------------------------------------------
# Canada HealthTech Symposium — Root .htaccess (Apache)
# ---------------------------------------------------------------

# ── Directory listing ────────────────────────────────────────
Options -Indexes

# ── Protect sensitive files ──────────────────────────────────
<FilesMatch "^\.env(\..*)?$">
    Order deny,allow
    Deny from all
</FilesMatch>

<FilesMatch "(composer\.json|composer\.lock|package\.json|package-lock\.json)$">
    Order deny,allow
    Deny from all
</FilesMatch>

<FilesMatch "\.(log|sql|sh|bak|swp|orig|inc)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Protect the installer lock file
<Files "install.lock">
    Order deny,allow
    Deny from all
</Files>

# ── Security headers ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Rewrite engine ───────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS (enable on production by removing the leading #)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Block access to hidden files and directories (except .well-known)
    RewriteCond %{REQUEST_URI} !^/\.well-known/
    RewriteRule (^\.|/\.) - [F,L]
</IfModule>

# ── PHP settings (if using mod_php) ──────────────────────────
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value session.cookie_httponly 1
    php_value session.use_only_cookies 1
    php_value session.use_strict_mode 1
</IfModule>
